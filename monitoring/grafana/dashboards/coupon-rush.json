{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate (per second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{uri=\"/api/v1/coupons/{couponId}/issue\"}[10s]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Avg Response Time (by status)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_sum{uri=\"/api/v1/coupons/{couponId}/issue\"}[10s])) / sum by (status) (rate(http_server_requests_seconds_count{uri=\"/api/v1/coupons/{couponId}/issue\"}[10s]))",
          "legendFormat": "avg {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HikariCP Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_max",
          "legendFormat": "max",
          "refId": "C"
        }
      ]
    },
    {
      "title": "HikariCP Pending Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hikaricp_connections_pending",
          "legendFormat": "pending",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tomcat Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "tomcat_threads_current_threads",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "expr": "tomcat_threads_busy_threads",
          "legendFormat": "busy",
          "refId": "B"
        },
        {
          "expr": "tomcat_threads_config_max_threads",
          "legendFormat": "max",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Tomcat Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "tomcat_connections_current_connections",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "expr": "tomcat_connections_keepalive_current_connections",
          "legendFormat": "keepalive",
          "refId": "B"
        }
      ]
    },
    {
      "title": "System CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "percentunit",
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "system_cpu_usage",
          "legendFormat": "system CPU",
          "refId": "A"
        },
        {
          "expr": "process_cpu_usage",
          "legendFormat": "process CPU",
          "refId": "B"
        }
      ]
    },
    {
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "used {{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "max {{id}}",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["coupon-rush"],
  "templating": { "list": [] },
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s"] },
  "timezone": "Asia/Seoul",
  "title": "Coupon Rush - Load Test",
  "uid": "coupon-rush-load-test",
  "version": 1
}
